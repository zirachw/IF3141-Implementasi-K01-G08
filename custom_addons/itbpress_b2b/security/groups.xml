<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Category makes groups mutually exclusive (radio in user form) -->
    <record id="module_category_itbpress_b2b" model="ir.module.category">
        <field name="name">ITB Press B2B</field>
        <field name="sequence">100</field>
        <field name="exclusive" eval="True"/>
    </record>

    <record id="group_direktur" model="res.groups">
        <field name="name">Direktur</field>
        <field name="category_id" ref="module_category_itbpress_b2b"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_staf_marketing" model="res.groups">
        <field name="name">Staf Marketing</field>
        <field name="category_id" ref="module_category_itbpress_b2b"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_direktur'))]"/>
    </record>
</odoo>
